{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "apps/api/Dockerfile",
    "buildCommand": "docker build -t job-agent-api -f apps/api/Dockerfile ."
  },
  "deploy": {
    "startCommand": "sh -c 'alembic upgrade head && uvicorn main:app --host 0.0.0.0 --port $PORT --workers 2'",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 30,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
